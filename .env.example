# ==========================================
# SPOTIFY CLONE - ENVIRONMENT CONFIGURATION
# ==========================================

# ----------------------------
# BACKEND EXPRESS API CONFIG
# ----------------------------
PORT=5000
NODE_ENV=development
JWT_SECRET=spotify_clone_secret_key_123

# Database Connection (MongoDB local or Atlas URI)
MONGO_URI=mongodb://127.0.0.1:27017/spotify_clone

# Cloudinary Setup (Optional: missing keys fall back to local disk storage uploads)
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# Allowed CORS client URL
FRONTEND_URL=http://localhost:3000

# ----------------------------
# FRONTEND VITE CLIENT CONFIG
# ----------------------------
VITE_API_URL=http://localhost:5000/api
