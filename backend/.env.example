# Backend Server Configuration
PORT=5000
NODE_ENV=development

# Database Connection
MONGO_URI=mongodb://127.0.0.1:27017/spotify_clone

# JWT Security Secret
JWT_SECRET=spotify_clone_secret_key_123

# Cloudinary Configuration (Optional - Falls back to local disk storage if missing)
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# Frontend Client URL (For CORS checking)
FRONTEND_URL=http://localhost:3000
